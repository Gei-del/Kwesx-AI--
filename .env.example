# ============================================================
# Kwesx AI — Variables de entorno
# Copiar este archivo a .env y rellenar los valores reales.
# NUNCA subir .env al repositorio (ya está en .gitignore).
# Ver docs/CONFIGURACION.md para descripción completa de cada variable.
# ============================================================

# --- Base de datos PostgreSQL ---
POSTGRES_USER=kwesx
POSTGRES_PASSWORD=kwesx_dev_2026
POSTGRES_DB=kwesx_db
# Puerto publicado en el host (5433 para no chocar con PostgreSQL local en 5432)
DB_PORT=5433
DATABASE_URL=postgresql+asyncpg://kwesx:kwesx_dev_2026@localhost:5433/kwesx_db
DATABASE_URL_SYNC=postgresql+psycopg2://kwesx:kwesx_dev_2026@localhost:5433/kwesx_db

# --- API datos.gov.co (Socrata) ---
# Token opcional: sin token funciona pero con límite de 1000 req/hora.
# Crear cuenta gratis en https://data.socrata.com/profile
SOCRATA_APP_TOKEN=

# --- IDs de datasets en datos.gov.co ---
ANI_DATASET_ID=8yi9-t44c
UPRA_DATASET_ID=gwbi-fnzs
IDEAM_PRECIPITACION_ID=s54a-sgyg
IDEAM_TEMPERATURA_ID=sbwg-7ju4
IDEAM_CATALOGO_ID=hp9r-jxuu

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true
SECRET_KEY=cambia-esto-en-produccion
# Generar en produccion: openssl rand -hex 32
ALLOWED_ORIGINS=http://localhost:3000

# --- ETL ---
# Cuantos registros traer por lote (Socrata max = 50000)
ETL_BATCH_SIZE=10000
# Rango de fechas para carga inicial (ISO 8601)
ETL_FECHA_INICIO=2021-01-01
ETL_FECHA_FIN=2026-06-30

# --- Frontend (Next.js) ---
# Desarrollo: http://localhost:8000
# Produccion: https://kwesx-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Push Notifications (VAPID) - cuando se active ---
# Generar con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=admin@kwesx.ai

# --- ML ---
ML_MODELS_PATH=ml/models
ML_RANDOM_SEED=2026
ML_N_JOBS=-1
ML_FORECAST_HORIZON=6
