# Kwesx AI — .gitattributes
# Normalización de saltos de línea entre plataformas

# Auto-detect text files and use LF
* text=auto eol=lf

# Archivos de texto explícitos
*.py          text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.json        text eol=lf
*.md          text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.toml        text eol=lf
*.cfg         text eol=lf
*.ini         text eol=lf
*.css         text eol=lf
*.html        text eol=lf
*.sh          text eol=lf
*.env.example text eol=lf
Makefile      text eol=lf

# Archivos binarios — nunca convertir
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.svg    text eol=lf
*.webp   binary
*.pdf    binary
*.pkl    binary
*.joblib binary
*.h5     binary

# Estadísticas de lenguaje en GitHub
*.md      linguist-documentation
*.yml     linguist-generated=false
Makefile  linguist-language=Makefile
